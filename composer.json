{
    "name": "village-community/digital-platform",
    "description": "Village Community Digital Platform - Modular Monolith",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "validate-contracts": "php bin/validate-contracts.php"
    },
    "config": {
        "sort-packages": true
    }
}
