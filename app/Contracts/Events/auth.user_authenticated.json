{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "auth.user_authenticated",
  "description": "Emitted when a user successfully authenticates via an identity provider",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_name": { "type": "string", "const": "auth.user_authenticated" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "actor_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "format": "uuid" },
        "provider": { "type": "string", "description": "Identity provider name, e.g. google" },
        "provider_subject": { "type": "string", "description": "Provider-scoped subject identifier" },
        "session_id": { "type": "string", "format": "uuid" },
        "ip_address": { "type": "string", "description": "IPv4 or IPv6 address of the requester" }
      },
      "required": ["user_id", "provider", "provider_subject", "session_id", "ip_address"],
      "additionalProperties": false
    }
  },
  "required": ["event_id", "event_name", "occurred_at", "actor_id", "correlation_id", "causation_id", "payload"]
}
