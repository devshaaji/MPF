{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "projects.project_published",
  "description": "Emitted when a project is transitioned from draft to published status",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_name": { "type": "string", "const": "projects.project_published" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "actor_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "properties": {
        "project_id": { "type": "string", "format": "uuid" },
        "owner_id": { "type": "string", "format": "uuid" },
        "title": { "type": "string" },
        "published_at": { "type": "string", "format": "date-time" }
      },
      "required": ["project_id", "owner_id", "title", "published_at"],
      "additionalProperties": false
    }
  },
  "required": ["event_id", "event_name", "occurred_at", "actor_id", "correlation_id", "causation_id", "payload"]
}
