{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "users.points_awarded",
  "description": "Emitted when points are awarded to a user from any source",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_name": { "type": "string", "const": "users.points_awarded" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "actor_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "format": "uuid" },
        "points_delta": { "type": "integer", "description": "Points added (positive) or deducted (negative)" },
        "source": { "type": "string", "description": "Source module or action that triggered the award" },
        "reference_id": { "type": "string", "format": "uuid", "description": "ID of the source entity (e.g. submission_id, topic_id)" },
        "new_total": { "type": "integer", "minimum": 0 }
      },
      "required": ["user_id", "points_delta", "source", "reference_id", "new_total"],
      "additionalProperties": false
    }
  },
  "required": ["event_id", "event_name", "occurred_at", "actor_id", "correlation_id", "causation_id", "payload"]
}
