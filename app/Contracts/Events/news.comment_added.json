{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "news.comment_added",
  "description": "Emitted when a comment is added to a news article",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_name": { "type": "string", "const": "news.comment_added" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "actor_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "properties": {
        "comment_id": { "type": "string", "format": "uuid" },
        "news_id": { "type": "string", "format": "uuid" },
        "commenter_id": { "type": "string", "format": "uuid" }
      },
      "required": ["comment_id", "news_id", "commenter_id"],
      "additionalProperties": false
    }
  },
  "required": ["event_id", "event_name", "occurred_at", "actor_id", "correlation_id", "causation_id", "payload"]
}
