{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "forms.submission_received",
  "description": "Emitted when a form submission is successfully persisted",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_name": { "type": "string", "const": "forms.submission_received" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "actor_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "properties": {
        "submission_id": { "type": "string", "format": "uuid" },
        "form_id": { "type": "string", "format": "uuid" },
        "submitter_id": { "type": "string", "format": "uuid" },
        "submitted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["submission_id", "form_id", "submitter_id", "submitted_at"],
      "additionalProperties": false
    }
  },
  "required": ["event_id", "event_name", "occurred_at", "actor_id", "correlation_id", "causation_id", "payload"]
}
