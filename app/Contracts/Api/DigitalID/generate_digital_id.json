{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "GenerateDigitalId",
  "description": "Contract for POST /api/v1/digital-id/generate — generate a digital identity artifact for a user",
  "request": {
    "type": "object",
    "properties": {
      "user_id": { "type": "string", "format": "uuid" }
    },
    "required": ["user_id"],
    "additionalProperties": false
  },
  "response": {
    "type": "object",
    "properties": {
      "digital_id": { "type": "string", "format": "uuid" },
      "user_id": { "type": "string", "format": "uuid" },
      "artifact_path": { "type": "string", "description": "Storage path to the generated identity artifact" },
      "checksum": { "type": "string", "description": "SHA-256 hex checksum of the artifact file" },
      "generated_at": { "type": "string", "format": "date-time" }
    },
    "required": ["digital_id", "user_id", "artifact_path", "checksum", "generated_at"],
    "additionalProperties": false
  }
}
