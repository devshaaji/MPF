{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "GetAdminDashboard",
  "description": "Contract for GET /api/v1/admin/dashboard — retrieve aggregate platform statistics. Required role: admin",
  "request": {
    "type": "object",
    "description": "No request body. Caller must have admin role (enforced via JWT claims).",
    "properties": {},
    "additionalProperties": false
  },
  "response": {
    "type": "object",
    "properties": {
      "stats": {
        "type": "object",
        "properties": {
          "total_users": { "type": "integer", "minimum": 0 },
          "active_users": { "type": "integer", "minimum": 0 },
          "total_topics": { "type": "integer", "minimum": 0 },
          "pending_moderation": { "type": "integer", "minimum": 0 }
        },
        "required": ["total_users", "active_users", "total_topics", "pending_moderation"],
        "additionalProperties": false
      },
      "generated_at": { "type": "string", "format": "date-time" }
    },
    "required": ["stats", "generated_at"],
    "additionalProperties": false
  }
}
