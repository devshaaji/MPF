{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "CreateCampaign",
  "description": "Contract for POST /api/v1/ads/campaigns — create a new advertising campaign",
  "request": {
    "type": "object",
    "properties": {
      "title": { "type": "string", "minLength": 1, "maxLength": 200 },
      "advertiser_id": { "type": "string", "format": "uuid" },
      "start_date": { "type": "string", "format": "date" },
      "end_date": { "type": "string", "format": "date" },
      "budget": { "type": "number", "minimum": 0, "exclusiveMinimum": true },
      "targeting": {
        "type": "object",
        "properties": {
          "location": { "type": "string" },
          "age_range": { "type": "string", "description": "e.g. 18-35" }
        },
        "additionalProperties": false
      }
    },
    "required": ["title", "advertiser_id", "start_date", "end_date", "budget"],
    "additionalProperties": false
  },
  "response": {
    "type": "object",
    "properties": {
      "campaign_id": { "type": "string", "format": "uuid" },
      "status": { "type": "string", "enum": ["draft", "pending_review", "active", "paused", "ended"] },
      "created_at": { "type": "string", "format": "date-time" }
    },
    "required": ["campaign_id", "status", "created_at"],
    "additionalProperties": false
  }
}
