{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "UpdateNotificationPreferences",
  "description": "Contract for PUT /api/v1/notifications/preferences — update a user's notification preferences",
  "request": {
    "type": "object",
    "properties": {
      "user_id": { "type": "string", "format": "uuid" },
      "channels": {
        "type": "object",
        "properties": {
          "email": { "type": "boolean" },
          "push": { "type": "boolean" },
          "in_app": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "topics": {
        "type": "object",
        "properties": {
          "news": { "type": "boolean" },
          "forum": { "type": "boolean" },
          "scholarship": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "required": ["user_id"],
    "additionalProperties": false
  },
  "response": {
    "type": "object",
    "properties": {
      "user_id": { "type": "string", "format": "uuid" },
      "channels": {
        "type": "object",
        "properties": {
          "email": { "type": "boolean" },
          "push": { "type": "boolean" },
          "in_app": { "type": "boolean" }
        },
        "required": ["email", "push", "in_app"],
        "additionalProperties": false
      },
      "topics": {
        "type": "object",
        "properties": {
          "news": { "type": "boolean" },
          "forum": { "type": "boolean" },
          "scholarship": { "type": "boolean" }
        },
        "required": ["news", "forum", "scholarship"],
        "additionalProperties": false
      }
    },
    "required": ["user_id", "channels", "topics"],
    "additionalProperties": false
  }
}
